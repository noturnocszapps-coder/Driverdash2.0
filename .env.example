# Supabase Configuration
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google OAuth Setup:
# 1. Go to Supabase > Authentication > Providers > Google
# 2. Enable Google Provider
# 3. Add Client ID and Client Secret from Google Cloud Console
# 4. Add your site URL to Redirect URIs in Google Cloud Console
# 5. Add authorized redirect URIs in Supabase:
#    - Web/PWA: http://localhost:3000/login
#    - Android/Capacitor: br.com.ntaplicacoes.driverdash://login

VITE_GEMINI_API_KEY=your-gemini-key
